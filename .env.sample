PRIMARY_ENV=production

SERVER_PORT=8080
SERVER_READ_TIMEOUT=15
SERVER_WRITE_TIMEOUT=15
SERVER_IDLE_TIMEOUT=60
# Comma-separated IPs or CIDRs. Empty = allow all.
# SERVER_ALLOWED_IPS=10.0.0.0/8,192.168.1.100

DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=exec0
DATABASE_SSL_MODE=disable
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=25
DATABASE_CONN_MAX_LIFETIME=30
DATABASE_CONN_MAX_IDLE_TIME=15

REDIS_ADDRESS=redis:6379

WORKER_CONCURRENCY=4
WORKER_METRICS_PORT=9091

# Execution limits for stdout/stderr (in bytes, default 10MB)
# EXECUTION_MAX_STDOUT_BYTES=10485760
# EXECUTION_MAX_STDERR_BYTES=10485760

OTEL_ENDPOINT=otel-collector:4317
OTEL_SERVICE_NAME=
